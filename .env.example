# Optional. Leave unset for local dev — the `seed` service in this
# compose provisions a default agent in your local OpenBox stack and
# writes the runtime API key into a shared volume that n8n picks up on
# startup. Set this to override (e.g. when pointing at staging/prod).
# OPENBOX_API_KEY=obx_live_replace_me

# Core endpoint. Defaults to the local docker stack over the shared
# network. Use https://core.openbox.ai for production.
OPENBOX_API_URL=http://openbox-core-server:8086

# OpenRouter is the hosted/default LLM path. Leave the key empty for local
# Ollama-only demos.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama runs as a container on the same docker network. The model is
# auto-pulled on first start by the `ollama-pull` init service. Smaller
# models = faster pull / smaller cache. Examples: tinyllama (~640MB),
# llama3.2:1b (~1.3GB), llama3.2:3b (~2GB).
OLLAMA_MODEL=tinyllama

# Optional: override the postgres credentials used for n8n's own state.
# These are local-only; nothing here is shared with OpenBox.
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n
POSTGRES_DB=n8n

# Optional HubSpot Free CRM branch. Create a HubSpot private app credential in
# n8n, then enable this.
HUBSPOT_CRM_ENABLED=false

# Optional Slack branch. Create a Slack bot token/signing-secret credential in
# n8n and set this to the target channel ID, for example C0123456789.
SLACK_CHANNEL_ID=

# n8n internal secrets. The defaults are fine for local; rotate if you
# expose this beyond localhost.
# PRODUCTION WARNING: Generate strong secrets before deploying:
#   openssl rand -hex 32
# These keys encrypt credentials at rest. If changed, existing credentials become unreadable.
N8N_ENCRYPTION_KEY=example-only-encryption-key
N8N_USER_MANAGEMENT_JWT_SECRET=example-only-jwt-secret
N8N_LOG_LEVEL=info

# External hooks configuration (Phase 2 observability)
# Self-hosted only — EXTERNAL_HOOK_FILES is not available on n8n Cloud.
# On n8n Cloud use the explicit OpenBox node as a checkpoint instead.
OPENBOX_HOOKS_ENABLED=true
OPENBOX_HOOKS_HTTP=true
OPENBOX_HOOKS_DB=true
OPENBOX_HOOKS_DEBUG=false

# Phase 3: pre-query DB blocking (self-hosted only, opt-in).
# Set OPENBOX_HOOKS_DB_BLOCKING=true to await a governance verdict before
# each Postgres query. Adds one network RTT per query.
# OPENBOX_HOOKS_DB_BLOCKING=false
# OPENBOX_HOOKS_DB_FAIL_OPEN=false

# Native OpenTelemetry tracing (Phase 2.2 - n8n v2.19+)
# Set N8N_OTEL_ENABLED=true and point at your OTLP collector.
# N8N_OTEL_TRACES_INCLUDE_NODE_SPANS adds per-node spans and injects
# W3C traceparent on HTTP Request nodes automatically.
# N8N_OTEL_ENABLED=false
# N8N_OTEL_EXPORTER_OTLP_ENDPOINT=http://your-collector:4318
# N8N_OTEL_TRACES_INCLUDE_NODE_SPANS=true

# Governance proxy configuration (Phase 3 blocking - optional)
# Activate with: docker compose --profile proxy up
# OPENBOX_PROXY_FAIL_OPEN=false
# OPENBOX_PROXY_TIMEOUT_MS=5000
# OPENBOX_PROXY_DEBUG=false

# Phase 3: HTTP body capture in proxy (self-hosted only, opt-in).
# Buffers req+res bodies up to BODY_CAP_BYTES and emits a span.
# OPENBOX_PROXY_BODY_CAPTURE=false
# OPENBOX_PROXY_BODY_CAP_BYTES=65536
